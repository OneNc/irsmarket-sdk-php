{
    "name": "onenc/irsmarket-sdk-php",
    "description": "PHP Client Library for IRSMarket API - Access digital product transactions (pulsa, kuota, voucher, etc.)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "OneNc Gids",
            "email": "onenc.gids@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "IRSMarket\\API\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IRSMarket\\API\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=PSR12 src/ tests/"
    }
}