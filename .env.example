# IRSMarket API Configuration
# Copy this file to .env and fill in your credentials

# Your API Key from IRSMarket dashboard
IRSMARKET_API_KEY=your_api_key_here

# Your API Secret from IRSMarket dashboard
IRSMARKET_API_SECRET=your_api_secret_here

# Request timeout in seconds (optional, default: 30)
IRSMARKET_TIMEOUT=30
